{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stored information about the registered users including their personal details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "address": { "type": "string" },
        "country": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "profileCompleted": { "type": "boolean" }
      },
      "required": ["uid", "email", "address", "country", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles keyed by their authentication UID."
    }
  }
}
